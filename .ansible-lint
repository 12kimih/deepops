---
# Project-level ansible-lint configuration for ansible-lint 26.x
# Profile levels: min, basic, moderate, safety, shared, production
#
# The repo is held at the strict `production` profile so that the consistency
# rules already cleaned up across the tree -- FQCN module names, capitalized
# task/play names, jinja spacing, task key ordering, and YAML style (truthy,
# octal modes) -- stay enforced in CI and cannot regress.
profile: production

# Don't auto-install requirements.yml at lint time. The galaxy roles are already
# vendored under roles/galaxy/ (on roles_path via ansible.cfg) and the collections
# come from the pip-installed ansible, so the network install only added a flaky
# GitHub-download step that timed out in CI ("failed to download ... read timed out").
offline: true

# Exclude external/vendored roles and hardware-specific roles
exclude_paths:
  - roles/galaxy/
  - roles/nvidia-dgx/
  - roles/nvidia-dgx-firmware/
  - roles/nvidia-gpu-tests/
  - submodules/
  # Molecule scenarios are test scaffolding (hosts: all playbooks). The standalone
  # `ansible-lint roles/` job syntax-checks them, which fails in CI without the full
  # molecule/galaxy/collections environment (collection version skew between the
  # pip-bundled and project-required community.* versions). They are exercised by
  # `molecule test` (the molecule workflow) instead.
  - roles/*/molecule/

# Pre-existing, higher-risk issues that are NOT auto-fixable and are being
# addressed incrementally as each subsystem is modernized. These are the only
# categories still allowed; everything else (incl. fqcn/name/jinja/key-order)
# must pass.
skip_list:
  - role-name                    # DeepOps role dirs use hyphens (dns-config, ood-wrapper, ...)
  - var-naming[no-role-prefix]   # vars not prefixed with the role name
  - var-naming[pattern]          # non-conforming variable names
  - name[play]                   # plays missing a descriptive name
  - name[missing]                # tasks missing a name
  - no-changed-when              # commands without changed_when
  - no-free-form                 # free-form module invocation
  - no-handler                   # change-driven tasks that could be handlers
  - risky-shell-pipe             # shell pipes without pipefail
  - risky-file-permissions       # file/copy tasks without an explicit mode
  - command-instead-of-module    # raw command where a module exists
  - command-instead-of-shell     # shell used where command would do
  - meta-no-tags                 # role meta missing galaxy_tags
  - schema[meta]                 # role meta/main.yml schema gaps
  - schema[requirements]         # non-standard requirements.yml entries
  - yaml[line-length]            # long lines (> 160 chars)
  - ignore-errors                # pre-existing ignore_errors usage
