#!/usr/bin/env csh
# Register the site modulefiles tree with Lmod via LMOD_SITE_MODULEPATH (z00_lmod
# reads it before Lmod init, prepends it to MODULEPATH, and preserves it across
# `module reset`). Generic: {{ cuda_modroot }} may hold many packages, not only
# CUDA. https://lmod.readthedocs.io/en/latest/090_configuring_lmod.html
if ( ! $?LMOD_SITE_MODULEPATH ) then
    setenv LMOD_SITE_MODULEPATH "{{ cuda_modroot }}"
else
    setenv LMOD_SITE_MODULEPATH "{{ cuda_modroot }}:${LMOD_SITE_MODULEPATH}"
endif
