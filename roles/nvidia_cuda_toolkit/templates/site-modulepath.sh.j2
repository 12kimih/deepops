# Register the site modulefiles tree with Lmod (managed by the deepops nvidia_cuda_toolkit role).
# Generic: {{ cuda_modroot }} may hold many packages, not only CUDA.
#
# Mechanism: LMOD_SITE_MODULEPATH -- the official Lmod way to add a site
# MODULEPATH. This file sorts before z00_lmod, which (after setting its base
# MODULEPATH) prepends every LMOD_SITE_MODULEPATH entry via Lmod's addto, so the
# tree lands on MODULEPATH and survives 'module reset' even when cuda_modroot
# differs from the lmod role's sm_module_path. No stdout is emitted here: a print
# during shell startup would corrupt non-interactive sessions such as scp/rsync.
case ":${LMOD_SITE_MODULEPATH:-}:" in
  *":{{ cuda_modroot }}:"*) : ;;
  *) export LMOD_SITE_MODULEPATH="{{ cuda_modroot }}${LMOD_SITE_MODULEPATH:+:${LMOD_SITE_MODULEPATH}}" ;;
esac
