[Unit]
Description=Prometheus Node Exporter
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
TimeoutStartSec=0
Restart=always
RestartSec=10
ExecStartPre=-/usr/bin/docker stop %n
ExecStartPre=-/usr/bin/docker rm %n
ExecStartPre=/usr/bin/docker pull {{ node_exporter_container }}
ExecStart=/usr/bin/docker run --rm --network host --cpus={{ node_exporter_max_cpu }} --pid=host --name %n -v /:/host:ro,rslave -v {{ node_exporter_prom_dir }}:/run/prometheus {{ node_exporter_container }} --path.rootfs=/host --collector.textfile.directory="{{ node_exporter_prom_dir }}"

[Install]
WantedBy=multi-user.target
