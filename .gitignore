# ansible
*.retry

# ansible run logs (keep the logs/ dir via .gitkeep, ignore the logs themselves)
*.log
/logs/*
!/logs/.gitkeep

# misc.
.*.swp

# virtualenv
/.venv/

# ansible-lint / ansible runtime cache
/.ansible/

# claude code
/CLAUDE.md
/tasks/

# project-specific
/admin.conf
/config*/
!/config.example/
/roles/galaxy/
/collections/*
/k8s-config/
/kubectl
/tridentctl

# secrets -- never commit (Ansible Vault password files, plaintext creds)
.vault-pass
*.vault-pass
vault-password*
